# Токен бота MAX (кабинет разработчика MAX). Не коммитить значение.
MAX_TOKEN=

# Как в PROMOSTAFF-AGENCY BOT (Telegram) — можно переопределить.
# COMPANY_NAME=PROMOSTAFF AGENCY
# WEBSITE_URL=https://promostaff-agency.ru
# PORTFOLIO_URL=https://promostaff-agency.ru/#reviews
# CONTACT_PHONE=+7 (929) 556-56-96
# CONTACT_TELEGRAM=@promostaffagency
# CONTACT_EMAIL=Elektro.07@mail.ru

# Визитка (опционально): ссылка на бот PRO и т.д.
# PRO_TELEGRAM_BOT_URL=https://t.me/your_pro_bot

# Уведомления администраторам (опционально).
# Почта: Timeweb / любой SMTP. Пароль только в переменных окружения, не в git.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# NOTIFY_EMAIL_TO=admin@example.com
# или как в TG-боте: EMAIL_RECEIVER=...
# SMTP_USE_TLS=true
# Для порта 465 обычно SSL: SMTP_USE_TLS=false не нужен — используется SMTP_SSL.

# MAX: user_id контактов агентства (через запятую), куда бот пришлёт служебный текст.
# ADMIN_MAX_USER_IDS=123456789

# Локально порт по умолчанию 8000; на Timeweb обычно задаётся PORT
# PORT=8000

# Воронка и напоминания (как funnel_* в PROMOSTAFF PRO): Postgres + фоновый цикл.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# FUNNEL_REMINDERS_ENABLED=1
# FUNNEL_REMINDERS_INTERVAL_SEC=600
